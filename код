import requests

# Ваши данные
city = "Moscow"  # Можно менять на любой город
api_key = "139118da9fba9df54951c10e228675f4"  # Вставьте сюда ваш ключ

# Формируем запрос (исправленный URL)
url = f"https://api.openweathermap.org/data/2.5/weather?q={city}&units=metric&appid={api_key}"

# Получаем данные
response = requests.get(url)
data = response.json()

# Проверяем статус ответа и наличие данных
if response.status_code == 200:
    if 'main' in data:
        print(f"Температура в {city}: {data['main']['temp']} °C")
    else:
        print("Ошибка: в ответе API отсутствует ключ 'main'. Проверьте корректность запроса.")
else:
    print(f"Ошибка API: {data.get('message', 'Неизвестная ошибка')}")
